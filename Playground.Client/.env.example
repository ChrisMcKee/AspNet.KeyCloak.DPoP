# Usage:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your KeyCloak values before running the DPoP client.

# Your KEYCLOAK tenant domain (without https://)
KEYCLOAK_DOMAIN=your-domain.example.com

# API identifier from KEYCLOAK dashboard
KEYCLOAK_AUDIENCE=your-api-identifier

# Machine-to-Machine application credentials
KEYCLOAK_CLIENT_ID=your-m2m-client-id
KEYCLOAK_CLIENT_SECRET=your-m2m-client-secret

# API base URL (default: playground server)
API_BASE_URL=https://localhost:7168


